<ruleset xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://pmd.sourceforge.net/ruleset/2.0.0" name="Qulice Ruleset" xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.github.io/schema/ruleset_2_0_0.xsd">
  <description>
    This ruleset checks code for potential mess
  </description>
  <!--
    UnnecessaryVarargsArrayCreation is excluded due to a false positive
    when the explicit array is needed to disambiguate overloaded
    methods/constructors: removing it produces a compile error.
    Re-enable once PMD fixes it upstream.
    Upstream: https://github.com/pmd/pmd/issues/6611
    Downstream: https://github.com/yegor256/qulice/issues/1525
  -->
  <rule ref="category/java/bestpractices.xml">
    <exclude name="GuardLogStatement"/>
    <exclude name="LiteralsFirstInComparisons"/>
    <!--
      AvoidUsingHardCodedIP is excluded from the bulk import here and
      re-enabled below with a violationSuppressXPath that ignores
      hard-coded IP literals inside unit-test classes (those whose
      simple name ends with 'Test', 'IT', 'TestCase' or 'ITCase'),
      where IP literals are commonly used as fixture data.
      Downstream: https://github.com/yegor256/qulice/issues/713
    -->
    <exclude name="AvoidUsingHardCodedIP"/>
    <exclude name="UnnecessaryVarargsArrayCreation"/>
    <!--
      UnitTestShouldIncludeAssert is excluded because it doesn't traverse
      lambda bodies and therefore misses assertions placed inside lambdas.
      Re-enable once PMD fixes it upstream; until then, we use our own
      UnitTestShouldIncludeAssertRule that crosses lambda boundaries.
      Upstream: https://github.com/pmd/pmd/issues/4272
      Downstream: https://github.com/yegor256/qulice/issues/1524
    -->
    <exclude name="UnitTestShouldIncludeAssert"/>
    <!--
      UnitTestContainsTooManyAsserts is excluded because it counts
      Assertions.assertThrows as an assertion, producing false positives
      when a test wraps assertThrows(...).getMessage() inside assertThat
      to verify the thrown exception's message in a single logical check.
      Until PMD supports excluding method names, we use our own
      UnitTestContainsTooManyAssertsRule that ignores assertThrows.
      Downstream: https://github.com/yegor256/qulice/issues/1519
    -->
    <exclude name="UnitTestContainsTooManyAsserts"/>
    <exclude name="UnusedPrivateField"/>
    <!--
      UnitTestAssertionsShouldIncludeMessage (a.k.a. the deprecated
      JUnitAssertionsShouldIncludeMessage) treats the two-argument
      Hamcrest form MatcherAssert.assertThat(String reason, boolean
      assertion) as missing a message, because it matches any
      assertThat call with two arguments. We re-enable the rule with a
      violationSuppressXPath that skips this specific overload, where
      the first argument IS the message.
      Downstream: https://github.com/yegor256/qulice/issues/1315
    -->
    <exclude name="UnitTestAssertionsShouldIncludeMessage"/>
    <!--
      UnitTestShouldUseTestAnnotation (formerly
      JUnit4TestShouldUseTestAnnotation) flags any public method whose
      name starts with 'test' in a class whose name ends with 'Test'
      when the method is not annotated with a known test annotation.
      That breaks classes that use non-JUnit conventions such as
      g4s8/oot, whose test entry point is a bare
      'public static void test()' method with no annotation. We
      re-enable the rule below with a violationSuppressXPath that
      ignores such oot-style classes.
      Downstream: https://github.com/yegor256/qulice/issues/1064
    -->
    <exclude name="UnitTestShouldUseTestAnnotation"/>
  </rule>
  <rule ref="category/java/bestpractices.xml/AvoidUsingHardCodedIP">
    <properties>
      <property name="violationSuppressXPath">
        <value><![CDATA[
          .[
            ancestor::ClassDeclaration[1][
              ends-with(@SimpleName,'Test')
              or ends-with(@SimpleName,'IT')
              or ends-with(@SimpleName,'TestCase')
              or ends-with(@SimpleName,'ITCase')
            ]
          ]
        ]]></value>
      </property>
    </properties>
  </rule>
  <rule ref="category/java/bestpractices.xml/UnitTestShouldUseTestAnnotation">
    <properties>
      <property name="violationSuppressXPath">
        <value><![CDATA[
          .[
            ancestor::ClassDeclaration[1]
              /ClassBody
              /MethodDeclaration[
                @Name='test' and @Static=true() and @Visibility='public'
              ]
          ]
        ]]></value>
      </property>
    </properties>
  </rule>
  <rule ref="category/java/bestpractices.xml/UnitTestAssertionsShouldIncludeMessage">
    <properties>
      <property name="violationSuppressXPath">
        <value><![CDATA[
          .[
            @MethodName = 'assertThat'
            and count(ArgumentList/*) = 2
            and ArgumentList/*[1][pmd-java:typeIs('java.lang.String')]
            and ArgumentList/*[2][pmd-java:typeIs('boolean') or pmd-java:typeIs('java.lang.Boolean')]
          ]
        ]]></value>
      </property>
    </properties>
  </rule>
  <!--
    UnusedPrivateField treats statement-level increment or decrement
    and compound assignments (like plus-equals or minus-equals) as
    write-only, so a field that is read-modified-written but never
    read in a pure-read position gets flagged as unused. The
    suppression below keeps the rule active but ignores violations
    for fields that are referenced by an increment, decrement or
    compound assignment anywhere in the enclosing class or its
    nested classes.
    Downstream: https://github.com/yegor256/qulice/issues/1520
  -->
  <rule ref="category/java/bestpractices.xml/UnusedPrivateField">
    <properties>
      <property name="violationSuppressXPath">
        <value><![CDATA[
          .[
            @Name = ancestor::ClassDeclaration[1]
              //(
                UnaryExpression[@Operator = ('++', '--')]
                | AssignmentExpression[@Operator = ('+=', '-=', '*=', '/=', '%=', '&=', '|=', '^=', '<<=', '>>=', '>>>=')]
              )
              //(FieldAccess | VariableAccess)/@Name
          ]
        ]]></value>
      </property>
    </properties>
  </rule>
  <rule ref="category/java/codestyle.xml">
    <exclude name="AtLeastOneConstructor"/>
    <exclude name="ShortClassName"/>
    <exclude name="ShortMethodName"/>
    <exclude name="ShortVariable"/>
    <exclude name="ClassNamingConventions"/>
    <exclude name="CommentDefaultAccessModifier"/>
    <exclude name="LinguisticNaming"/>
    <exclude name="CallSuperInConstructor"/>
    <exclude name="UseDiamondOperator"/>
    <exclude name="UnnecessaryFullyQualifiedName"/>
  </rule>
  <rule ref="category/java/design.xml">
    <exclude name="LoosePackageCoupling"/>
    <exclude name="LawOfDemeter"/>
    <exclude name="SignatureDeclareThrowsException"/>
    <exclude name="ExcessiveImports"/>
    <exclude name="CyclomaticComplexity"/>
    <exclude name="FinalFieldCouldBeStatic"/>
    <exclude name="TooManyMethods"/>
  </rule>
  <rule ref="category/java/design.xml/TooManyMethods">
    <properties>
      <property name="violationSuppressXPath" value=".[ends-with(@SimpleName,'Test')]"/>
    </properties>
  </rule>
  <rule ref="category/java/documentation.xml">
    <exclude name="CommentRequired"/>
    <exclude name="CommentSize"/>
  </rule>
  <rule ref="category/java/errorprone.xml">
    <exclude name="AvoidFieldNameMatchingMethodName"/>
    <exclude name="AvoidLiteralsInIfCondition"/>
    <exclude name="NonSerializableClass"/>
    <exclude name="MissingSerialVersionUID"/>
    <exclude name="TestClassWithoutTestCases"/>
  </rule>
  <!--
    Recognise io.github.artsok annotations (@RepeatedIfExceptionsTest,
    @ParameterizedRepeatedIfExceptionsTest) as test cases so that
    TestClassWithoutTestCases does not flag classes that use them.
    Also recognise non-JUnit test conventions such as g4s8/oot, which
    uses a bare 'public static void test()' method as the entry point
    with no test annotation.
    Upstream: https://github.com/yegor256/qulice/issues/1521
    Downstream: https://github.com/yegor256/qulice/issues/1064
  -->
  <rule ref="category/java/errorprone.xml/TestClassWithoutTestCases">
    <properties>
      <property name="violationSuppressXPath">
        <value><![CDATA[
          .[
            .//Annotation[
              @SimpleName='RepeatedIfExceptionsTest'
              or @SimpleName='ParameterizedRepeatedIfExceptionsTest'
            ]
            or
            ClassBody/MethodDeclaration[
              @Name='test' and @Static=true() and @Visibility='public'
            ]
          ]
        ]]></value>
      </property>
    </properties>
  </rule>
  <rule ref="category/java/performance.xml">
    <exclude name="AvoidInstantiatingObjectsInLoops"/>
  </rule>
  <rule ref="category/java/multithreading.xml">
    <exclude name="AvoidUsingVolatile"/>
    <exclude name="UseConcurrentHashMap"/>
    <exclude name="DoNotUseThreads"/>
  </rule>
  <rule ref="category/java/errorprone.xml/AvoidDuplicateLiterals">
    <properties>
      <property name="maxDuplicateLiterals">
        <value>5</value>
      </property>
      <property name="skipAnnotations">
        <value>true</value>
      </property>
    </properties>
  </rule>
  <rule name="UnitTestShouldIncludeAssert" message="This unit test should include assert() or fail()" language="java" class="com.qulice.pmd.rules.UnitTestShouldIncludeAssertRule">
    <description>
      Unit tests should include at least one assertion. This variant of
      PMD's UnitTestShouldIncludeAssert rule looks for assertions placed
      inside lambda bodies as well, which the upstream rule misses.
    </description>
    <priority>3</priority>
  </rule>
  <rule name="UnitTestContainsTooManyAsserts" message="Unit tests should not contain more than 1 assert(s)." language="java" class="com.qulice.pmd.rules.UnitTestContainsTooManyAssertsRule">
    <description>
      Unit tests should not contain more than one assertion. This
      variant of PMD's UnitTestContainsTooManyAsserts rule does not
      count calls to assertThrows as assertions, so a test that wraps
      assertThrows(...).getMessage() inside an assertThat to verify the
      thrown exception's message is not flagged.
    </description>
    <priority>3</priority>
  </rule>
  <rule name="ProhibitPlainJunitAssertionsRule" message="Avoid using Plain JUnit assertions" language="java" class="com.qulice.pmd.rules.ProhibitPlainJunitAssertionsRule">
    <description>
      Instead of using plain JUnit assertions like org.junit.Assert.assert*
      junit.framework.Assert.assert* - use Matchers from package org.hamcrest
    </description>
  </rule>
  <rule name="UseStringIsEmptyRule" message="Use String.isEmpty() when checking for empty string" language="java" class="com.qulice.pmd.rules.UseStringIsEmptyRule">
    <description>
      Method String.isEmpty() should be used when testing for empty string,
      rather than using
      String.length() compared to 0
    </description>
  </rule>
  <rule name="UseCollectionsSingletonList" message="Use Collections.singletonList instead of Arrays.asList with a single non-array argument" language="java" class="com.qulice.pmd.rules.UseCollectionsSingletonListRule">
    <description>
      Arrays.asList with a single non-array argument allocates a one-element
      backing array via varargs and wraps it in a list. Collections.singletonList
      expresses the same intent with a single, immutable, fixed-size list and
      avoids the implicit array allocation.
    </description>
    <priority>3</priority>
  </rule>
  <rule name="ProhibitFormatInLoggerRule" message="Avoid String.format inside jcabi-log Logger calls; pass the format string and arguments directly" language="java" class="com.qulice.pmd.rules.ProhibitFormatInLoggerRule">
    <description>
      jcabi-log Logger methods (trace, debug, info, warn, error) already
      accept a printf-style format string with positional arguments, so
      pre-formatting the message with String.format is redundant. Inline
      the format string and pass the arguments directly to the Logger
      method instead.
    </description>
    <priority>3</priority>
  </rule>
  <rule name="UnnecessaryLocalRule" message="Avoid creating unnecessary local variables like ''{0}''" language="java" class="com.qulice.pmd.rules.UnnecessaryLocalRule">
  </rule>
  <rule name="ConstructorShouldDoInitialization" message="Avoid doing field initialization outside constructor." language="java" class="net.sourceforge.pmd.lang.rule.xpath.XPathRule">
    <description>
      Avoid doing field initialization outside class constructor.
      Such initialization is allowed only when there is no constructor.
    </description>
    <priority>3</priority>
    <properties>
      <property name="xpath">
        <value><![CDATA[
          //ClassDeclaration
          [count(ClassBody/ConstructorDeclaration)>0]
          [count(ClassBody/FieldDeclaration[@Static=false()]/VariableDeclarator[@Initializer=true()])>0]
        ]]></value>
      </property>
    </properties>
  </rule>
  <rule name="OnlyOneConstructorShouldDoInitialization" message="Avoid field initialization in several constructors." language="java" class="net.sourceforge.pmd.lang.rule.xpath.XPathRule">
    <description>
      Avoid doing field initialization in several constructors.
      Only one main constructor should do real work.
      Other constructors should delegate initialization to it.
    </description>
    <priority>3</priority>
    <properties>
      <property name="xpath">
        <value><![CDATA[
          //ClassDeclaration
              [count(ClassBody/ConstructorDeclaration)>1]
              [count(ClassBody/ConstructorDeclaration/Block[ExpressionStatement])>1]
        ]]></value>
      </property>
    </properties>
  </rule>
  <rule name="ConstructorOnlyInitializesOrCallOtherConstructors" message="Only field initialization or call to other constructors in a constructor." language="java" class="net.sourceforge.pmd.lang.rule.xpath.XPathRule">
    <description>
      Avoid putting anything other than field assignments into constructors.
      The only exception should be calling other constructors
      or calling super class constructor.
    </description>
    <priority>3</priority>
    <properties>
      <property name="xpath">
        <value><![CDATA[
          //ConstructorDeclaration/Block[
              count(ExpressionStatement[not(.//LambdaExpression)]) + count(LocalVariableDeclaration)
              !=
              count(ExpressionStatement/AssignmentExpression[not(.//LambdaExpression)]/FieldAccess/ThisExpression)
          ]
        ]]></value>
      </property>
    </properties>
  </rule>
  <!--
    Direct access to a static final field inside a static initializer is
    allowed because qualifying it with the class name would not compile
    (a final field can only be assigned once by its simple name).
    Downstream: https://github.com/yegor256/qulice/issues/719
  -->
  <rule name="AvoidDirectAccessToStaticFields" message="Static fields should be accessed in a static way [CLASS_NAME.FIELD_NAME]." language="java" class="net.sourceforge.pmd.lang.rule.xpath.XPathRule">
    <description>
      Avoid accessing static fields directly.
    </description>
    <priority>3</priority>
    <properties>
      <property name="xpath">
        <value><![CDATA[
          //VariableAccess[
            @Name = //FieldDeclaration[@Static=true()]/VariableDeclarator/VariableId/@Name
            and not(ancestor::Initializer[@Static=true()])
          ]
        ]]></value>
      </property>
    </properties>
  </rule>
  <rule name="AvoidAccessToStaticMembersViaThis" message="Static members should be accessed in a static way [CLASS_NAME.FIELD_NAME], not via instance reference." language="java" class="net.sourceforge.pmd.lang.rule.xpath.XPathRule">
    <description>
      Avoid accessing static fields or methods via instance with 'this' keyword.
    </description>
    <priority>3</priority>
    <properties>
      <property name="xpath">
        <value><![CDATA[
          //FieldAccess[
            ThisExpression
            and
            @Name =
              ancestor::ClassDeclaration[1]
                //FieldDeclaration[@Static=true()]
                  /VariableDeclarator
                  /VariableId/@Name
          ]
          |
           //MethodCall[
            ThisExpression
            and
            @MethodName =
              ancestor::ClassDeclaration[1]
                /ClassBody
                /MethodDeclaration[@Static=true()]
                  /@Name
          ]
        ]]></value>
      </property>
    </properties>
  </rule>
  <rule name="ProhibitPublicStaticMethods" message="Public static methods are prohibited." language="java" class="net.sourceforge.pmd.lang.rule.xpath.XPathRule">
    <description>
      Public static methods are prohibited.
    </description>
    <priority>3</priority>
    <properties>
      <property name="xpath">
        <value><![CDATA[
          //MethodDeclaration[
              @Static=true() and
              @Visibility='public' and not
              (@Name='main' and FormalParameters/FormalParameter/ArrayType/ClassType/@SimpleName='String' and VoidType) and not
              (ModifierList/Annotation[@SimpleName='BeforeClass' or @SimpleName='AfterClass' or @SimpleName='Parameters'])
          ]
      ]]></value>
      </property>
    </properties>
  </rule>
  <rule name="ProhibitFilesCreateFileInTests" message="Files.createFile should not be used in tests, replace them with @Rule TemporaryFolder" language="java" class="net.sourceforge.pmd.lang.rule.xpath.XPathRule">
    <description>
      Files.createFile shouldn't be used in tests.
    </description>
    <priority>3</priority>
    <properties>
      <property name="xpath">
        <value><![CDATA[
          //ClassDeclaration[ends-with(@SimpleName, 'Test')]//MethodCall[@MethodName='createFile' and TypeExpression/ClassType/@SimpleName='Files']
        ]]></value>
      </property>
    </properties>
  </rule>
  <rule name="JUnitTestClassShouldBeFinal" language="java" class="net.sourceforge.pmd.lang.rule.xpath.XPathRule" message="JUnit test class should be final">
    <description><![CDATA[
      Reports on JUnit test classes declared non-final.
    ]]></description>
    <priority>3</priority>
    <properties>
      <!--Solve priority conflict-->
      <property name="xpath">
        <value><![CDATA[
          //ClassDeclaration[
            @Interface = false()
            and
            @Final = false()
            and
            ancestor::CompilationUnit/ImportDeclaration[
              @ImportedName = 'junit.framework.TestCase'
              or
              @ImportedName = 'org.junit.Test'
              or
              @ImportedName = 'org.junit.jupiter.api.Test'
            ]
          ]
        ]]></value>
      </property>
    </properties>
  </rule>
</ruleset>
